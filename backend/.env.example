DATABASE_URL=sqlite:///./idxanalyst.db

# ── Autentikasi (Supabase Auth) ──────────────────────────────────────────────
# URL project Supabase (Project Settings > API > Project URL), mis:
# https://xxxxxxxx.supabase.co
# WAJIB bila project memakai kunci JWT asimetris (ES256/RS256) — default project baru.
SUPABASE_URL=
# Secret untuk verifikasi JWT Supabase LEGACY HS256 (Project Settings > API > JWT
# Secret / "Legacy JWT secret"). Hanya dipakai bila token bertanda tangan HS256.
SUPABASE_JWT_SECRET=
# Audience JWT Supabase (default 'authenticated' — biasanya tak perlu diubah):
# SUPABASE_JWT_AUD=authenticated
# Dev/local: lewati verifikasi JWT & pakai user dev (JANGAN aktif di produksi):
# AUTH_DEV_BYPASS=1
# AUTH_DEV_USER_ID=dev-user
# AUTH_DEV_TIER=dev

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origin frontend yang diizinkan (comma-separated). Default localhost dev.
# ALLOWED_ORIGINS=https://app.emetiq.com,https://emetiq.vercel.app

# ── AI Advisor (Groq) ────────────────────────────────────────────────────────
# Wajib untuk fitur advisor. Dapatkan key gratis di console.groq.com
GROQ_API_KEY=
# Opsional override model (Groq sering deprecate model):
# ADVISOR_ROUTER_MODEL=openai/gpt-oss-20b
# ADVISOR_REASONING_MODEL=openai/gpt-oss-120b

# ── Big Money (fitur dev-mode) ───────────────────────────────────────────────
# Ketiga variabel di bawah OPSIONAL. Tanpa semuanya, ingest IDX dan perhitungan
# skor tetap berjalan penuh — hanya laporan AI dan notifikasi Telegram yang
# dilewati. Data tak pernah gagal gara-gara lapisan kabar.
#
# Gemini menulis laporan harian. Terpisah dari Groq (yang tetap milik AI Advisor).
# Ambil key gratis di https://aistudio.google.com/apikey
GEMINI_API_KEY=
#
# Bot Telegram yang mengirim laporan harian. Token dari @BotFather.
TELEGRAM_BOT_TOKEN=
#
# Secret webhook Telegram — karangan Anda sendiri, bebas, cukup panjang.
# Webhook tak bisa memakai auth Supabase (pemanggilnya Telegram, bukan browser),
# jadi INI satu-satunya yang membedakan Telegram dari orang asing di internet.
# Nilainya harus sama dengan secret_token saat mendaftarkan webhook:
#   curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#     -d "url=https://<backend-anda>/bigmoney/telegram/webhook" \
#     -d "secret_token=<TELEGRAM_WEBHOOK_SECRET>"
TELEGRAM_WEBHOOK_SECRET=
